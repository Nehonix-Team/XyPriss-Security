{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "moduleResolution": "node",

    "lib": ["ESNext", "DOM"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "removeComments": false,
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "types": ["node", "bun"]
  },
  "include": ["./src/**/*"],
  "exclude": [
    "**/node_modules",
    "../../node_modules",
    "../../node_modules/**/*",
    "../../.private",
    "../../.private/**/*",
    "src/dist",
    "/private/**",
    "**/private/*",
    "src/integrations/react/**/*",
    "**/*.test.ts",
    "**/*.spec.ts"
  ]
}
